{
  "name": "shoprpa-workspace",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "scripts": {
    "cz": "cz",
    "preinstall": "npx only-allow pnpm",
    "lint": "eslint \"packages/*/src/**/*.{vue,ts,tsx,js,jsx}\" \"packages/*/*.{js,ts,mts,cjs}\"",
    "lint:fix": "eslint --fix \"packages/*/src/**/*.{vue,ts,tsx,js,jsx}\" \"packages/*/*.{js,ts,mts,cjs}\"",
    "set-env": "corepack pnpm --filter @rpa/web-app run set-env",
    "set-env:saas": "corepack pnpm --filter @rpa/web-app run set-env saas",
    "set-env:enterprise": "corepack pnpm --filter @rpa/web-app run set-env enterprise",
    "dev:web": "corepack pnpm --filter @rpa/web-app run dev",
    "dev:desktop": "corepack pnpm --filter shoprpa run dev",
    "build:web": "corepack pnpm --filter @rpa/web-app run build",
    "build:desktop": "corepack pnpm --filter @rpa/extension run build:bridge-inject && corepack pnpm --filter shoprpa run build:portable && corepack pnpm --filter shoprpa run verify:portable",
    "verify:release": "corepack pnpm run lint && corepack pnpm run test:run && corepack pnpm --filter shoprpa run typecheck && corepack pnpm run build:desktop",
    "doctor:installer": "corepack pnpm --filter shoprpa run doctor:installer",
    "build:installer": "corepack pnpm --filter shoprpa run build:win",
    "i18n": "env-cmd lobe-i18n locale",
    "test": "node --import ./scripts/register-esbuild-config-loader.mjs node_modules/vitest/vitest.mjs",
    "test:ui": "node --import ./scripts/register-esbuild-config-loader.mjs node_modules/vitest/vitest.mjs --ui",
    "test:run": "node --import ./scripts/register-esbuild-config-loader.mjs node_modules/vitest/vitest.mjs run"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^5.4.1",
    "@lobehub/i18n-cli": "^1.25.1",
    "@types/node": "^22.18.10",
    "@vitest/ui": "3.2.4",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "env-cmd": "^10.1.0",
    "eslint": "^9.32.0",
    "eslint-plugin-format": "^1.0.1",
    "fast-glob": "^3.3.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.0",
    "vitest": "^3.2.4"
  },
  "volta": {
    "node": "22.15.0"
  }
}
