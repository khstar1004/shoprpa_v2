{
  "name": "@rpa/extension",
  "displayName": "ShopRPA Browser Extension",
  "version": "5.2.9",
  "description": "ShopRPA browser automation connector",
  "homepage": "https://shoprpa.local",
  "type": "commonjs",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "main": "background.js",
  "scripts": {
    "test": "node --import ../../scripts/register-esbuild-config-loader.mjs node_modules/vitest/vitest.mjs run --config vite.config.mts --pool=threads --poolOptions.threads.singleThread=true",
    "build": "node --import ../../scripts/register-esbuild-config-loader.mjs node_modules/vite/bin/vite.js build --config vite.config.mts",
    "build:firefox": "node --import ../../scripts/register-esbuild-config-loader.mjs node_modules/vite/bin/vite.js build --config vite.config.mts --mode=firefox",
    "build:360se": "node --import ../../scripts/register-esbuild-config-loader.mjs node_modules/vite/bin/vite.js build --config vite.config.mts --mode=360se",
    "build:360ChromeX": "node --import ../../scripts/register-esbuild-config-loader.mjs node_modules/vite/bin/vite.js build --config vite.config.mts --mode=360ChromeX",
    "build:chromium": "node --import ../../scripts/register-esbuild-config-loader.mjs node_modules/vite/bin/vite.js build --config vite.config.mts --mode=chromium",
    "build:bridge-inject": "node --import ../../scripts/register-esbuild-config-loader.mjs node_modules/vite/bin/vite.js build --config vite.bridge.config.mjs && node scripts/sync-bridge-inject.cjs",
    "build:publish": "node --import ../../scripts/register-esbuild-config-loader.mjs node_modules/vite/bin/vite.js build --config vite.config.mts --mode=publish",
    "test:browser": "node --import ../../scripts/register-esbuild-config-loader.mjs node_modules/vitest/vitest.mjs run --config=vitest.browser.config.js",
    "test:content:jsdom": "node --import ../../scripts/register-esbuild-config-loader.mjs node_modules/vitest/vitest.mjs run --config=vitest.content-jsdom.config.js",
    "coverage": "node --import ../../scripts/register-esbuild-config-loader.mjs node_modules/vitest/vitest.mjs --config=vitest.browser.config.js run --coverage",
    "build:all": "corepack pnpm run build && corepack pnpm run build:firefox && corepack pnpm run build:360se && corepack pnpm run build:360ChromeX && corepack pnpm run build:chromium",
    "lint:fix": "eslint --fix \"**/*.{ts,js}\""
  },
  "devDependencies": {
    "@babel/cli": "^7.25.6",
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.4",
    "@types/archiver": "^6.0.3",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "archiver": "^7.0.1",
    "chrome-types": "^0.1.290",
    "jsdom": "^27.0.0",
    "playwright": "^1.55.0",
    "vite": "^5.4.21",
    "vitest": "^3.2.4",
    "ws": "^8.18.0"
  }
}
