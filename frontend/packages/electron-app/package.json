{
  "name": "shoprpa",
  "version": "1.1.8",
  "description": "ShopRPA desktop automation client",
  "author": "ShopRPA",
  "homepage": "https://shoprpa.local",
  "main": "./out/main/index.js",
  "scripts": {
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "corepack pnpm run typecheck:node && corepack pnpm run typecheck:web",
    "start": "node --import ./scripts/register-esbuild-loader.mjs node_modules/electron-vite/bin/electron-vite.js preview --ignoreConfigWarning",
    "free:dev-port": "C:/Windows/System32/WindowsPowerShell/v1.0/powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/free-dev-port.ps1",
    "dev:web": "corepack pnpm --filter @rpa/web-app run dev",
    "dev:client": "node --import ./scripts/register-esbuild-loader.mjs node_modules/electron-vite/bin/electron-vite.js dev --watch --ignoreConfigWarning",
    "dev": "corepack pnpm run free:dev-port && corepack pnpm run build:sdk && run-p dev:web dev:client",
    "build": "corepack pnpm run build:sdk && corepack pnpm run typecheck && node --import ./scripts/register-esbuild-loader.mjs node_modules/electron-vite/bin/electron-vite.js build --ignoreConfigWarning && corepack pnpm run build:web",
    "build:legacy": "corepack pnpm --filter @rpa/web-app run build:legacy",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "corepack pnpm run build && electron-builder --dir",
    "build:portable": "corepack pnpm run build && node scripts/build-portable.js",
    "doctor:installer": "node scripts/check-installer-host.js",
    "build:win": "corepack pnpm run doctor:installer && corepack pnpm run build && electron-builder --win",
    "build:win32": "corepack pnpm run doctor:installer && corepack pnpm run build && electron-builder --win --ia32",
    "build:mac": "corepack pnpm run build && electron-builder --mac",
    "build:linux": "corepack pnpm run build && electron-builder --linux",
    "build:sdk": "tsdown --config tsdown.config.mts",
    "build:web": "corepack pnpm --filter @rpa/web-app run build && corepack pnpm run copy:renderer",
    "copy:renderer": "node scripts/copy-dist.js",
    "verify:portable": "node scripts/verify-portable.js"
  },
  "dependencies": {
    "await-to-js": "^3.0.0",
    "axios": "^1.7.4",
    "builder-util-runtime": "^9.5.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.7.3",
    "lodash-es": "^4.17.21",
    "node-7z": "^3.0.0",
    "tree-kill": "^1.2.2",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@rpa/shared": "workspace:*",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^18.15.0",
    "@types/node-7z": "^2.1.11",
    "electron": "^25.9.8",
    "electron-builder": "^24.13.3",
    "electron-vite": "^5.0.0",
    "tsdown": "catalog:",
    "typescript": "^5.5.2",
    "vite": "catalog:"
  }
}
