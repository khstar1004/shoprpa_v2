{
 "appId": "com.shoprpa.app",
 "productName": "shoprpa",
  "artifactName": "shoprpa-${version}-${arch}.${ext}",
  "electronLanguages": [
    "zh-CN",
    "en-US"
  ],
  "asar": false,
  "files": [
    "node_modules/**",
    "out/**",
    "extensions/**",
    "package.json"
  ],
  "extraFiles": [
    {
      "from": "../../../resources",
      "to": "resources"
    }
  ],
  "win": {
    "target": "nsis",
    "icon": "../../public/icons/icon.ico",
    "publisherName": "shoprpa",
    "verifyUpdateCodeSignature": false,
    "publish": {
      "provider": "generic",
      "url": ""
    }
  },
  "mac": {
    "target": "dmg",
    "icon": "../../public/icons/icon.png",
    "extendInfo": {
      "CFBundleURLTypes": [
        {
     "CFBundleURLName": "com.shoprpa.app",
     "CFBundleURLSchemes": ["shoprpa"]
        }
      ]
    }
  },
  "linux": {
    "target": "deb",
    "icon": "../../public/icons/icon.png",
    "category": "Utility",
    "desktop": {
   "MimeType": "x-scheme-handler/shoprpa;"
    }
  },
  "nsis": {
    "include": "./installer.nsh",
    "oneClick": false,
    "allowElevation": true,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "shoprpa"
  }
}
