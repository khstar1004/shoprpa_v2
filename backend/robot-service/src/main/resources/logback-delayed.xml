<configuration scan="true" scanPeriod="3 seconds">
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <!-- 변수 -->
    <springProperty scope="context" name="logLevel" source="log.file.level" defaultValue="info"/>
    <springProperty scope="context" name="appName" source="spring.application.name" defaultValue="none"/>

    <!--로그출력로제어-->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>${logLevel}</level>
        </filter>

        <encoder charset="UTF-8">
            <!--Log format: %d date, Asia/Seoul timezone, %thread thread name, %-5level log level, %msg message, %n newline -->
            <pattern>%d{yyyy-MM-dd HH:mm:ss,Asia/Seoul} %green([%thread]) %yellow(${PID}) %highlight(%-5level)
                %boldMagenta(%logger{10}.%M\(%F:%L\))- %cyan(%msg%n)
            </pattern>

        </encoder>
    </appender>

    <!--로그출력로파일-->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>${logLevel}</level>
        </filter>

        <layout class="ch.qos.logback.classic.PatternLayout">
            <Pattern>%d{HH:mm:ss.SSS,Asia/Seoul} [%thread] %-5level %logger{32} - %msg%n</Pattern>
        </layout>

        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!--로그파일출력의파일이름 -->
            <FileNamePattern>/opt/log/rpa/${appName}/logFile.%d{yyyy-MM-dd_HH}.%i.log</FileNamePattern>
            <!--<FileNamePattern>~/Desktop/var/log/rpa/${appName}/logFile.%d{yyyy-MM-dd_HH}.%i.log</FileNamePattern>-->
            <!--로그파일보관데이터 -->
            <maxHistory>4320</maxHistory>
            <!--제어단일개로그파일의크기 -->
            <maxFileSize>20MB</maxFileSize>
            <!--사용제어모든파일의크기-->
            <totalSizeCap>10GB</totalSizeCap>
        </rollingPolicy>
    </appender>


