{
  "name": "astron-rpa-workspace",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "verify:portable": "corepack pnpm --filter shoprpa run verify:portable",
    "verify:portable:host": "node scripts/run-powershell.cjs scripts/verify-portable-host.ps1",
    "smoke:portable": "node scripts/run-powershell.cjs scripts/run-portable-smoke.ps1",
    "smoke:portable-renderer": "node scripts/run-powershell.cjs scripts/run-portable-renderer-smoke.ps1",
    "smoke:backend-offline": "node scripts/run-powershell.cjs scripts/run-backend-offline-smoke.ps1",
    "smoke:workflow-editor": "node scripts/run-powershell.cjs scripts/run-workflow-editor-smoke.ps1",
    "build:desktop": "corepack pnpm --dir frontend run build:desktop",
    "doctor:installer": "corepack pnpm --dir frontend run doctor:installer",
    "doctor:release": "node scripts/run-powershell.cjs scripts/doctor-release.ps1",
    "doctor:release:strict": "node scripts/run-powershell.cjs scripts/doctor-release.ps1 -Strict",
    "verify:release": "corepack pnpm --dir frontend run verify:release && corepack pnpm run typecheck:frontend && corepack pnpm run test:frontend && corepack pnpm --dir frontend --filter @rpa/extension run build:chromium && corepack pnpm run verify:browser-extension-static && corepack pnpm run test:browser-extension-content:jsdom && corepack pnpm run verify:portable:host && corepack pnpm run test:engine-runtime && corepack pnpm run build:portable-installer:fast && corepack pnpm run verify:portable-installer",
    "verify:release:full": "node scripts/run-powershell.cjs scripts/verify-release-full.ps1",
    "verify:release:full:list": "node scripts/run-powershell.cjs scripts/verify-release-full.ps1 -List",
    "verify:release:full:refresh": "node scripts/run-powershell.cjs scripts/verify-release-full.ps1 -RefreshAuditOnly",
    "build:portable-installer": "node scripts/run-powershell.cjs scripts/build-portable-installer.ps1",
    "build:portable-installer:fast": "node scripts/run-powershell.cjs scripts/build-portable-installer.ps1 -SkipPortableVerify",
    "verify:portable-installer": "node scripts/run-powershell.cjs scripts/verify-portable-installer.ps1",
    "verify:gui-e2e": "node scripts/run-powershell.cjs scripts/verify-gui-browser-e2e-report.ps1",
    "template:gui-e2e": "node scripts/run-powershell.cjs scripts/verify-gui-browser-e2e-report.ps1 -WriteTemplate",
    "evidence:gui-e2e": "node scripts/run-powershell.cjs scripts/update-gui-browser-e2e-report-from-automated-evidence.ps1",
    "smoke:browser-extension": "node scripts/run-powershell.cjs scripts/run-browser-extension-smoke.ps1",
    "verify:browser-extension-static": "node scripts/verify-browser-extension-static.cjs",
    "verify:browser-extension-smoke": "node scripts/run-powershell.cjs scripts/verify-browser-extension-smoke-report.ps1",
    "test:browser-extension-content": "node scripts/run-powershell.cjs scripts/run-browser-extension-content-tests.ps1",
    "test:browser-extension-content:jsdom": "node scripts/run-powershell.cjs scripts/run-browser-extension-content-jsdom-tests.ps1",
    "repair:release-host": "node scripts/run-powershell.cjs scripts/repair-release-host.ps1",
    "repair:release-host:strict": "node scripts/run-powershell.cjs scripts/repair-release-host.ps1 -Strict",
    "repair:release-host:apply": "node scripts/run-powershell.cjs scripts/repair-release-host.ps1 -Apply",
    "typecheck:frontend": "node scripts/run-powershell.cjs scripts/run-frontend-typecheck.ps1",
    "test:frontend": "node scripts/run-powershell.cjs scripts/run-frontend-tests.ps1",
    "test:engine-runtime": "node scripts/run-powershell.cjs scripts/test-engine-runtime.ps1",
    "test:java-backends": "node scripts/run-powershell.cjs scripts/test-java-backends.ps1",
    "setup:python-backends": "node scripts/run-powershell.cjs scripts/setup-python-backends.ps1",
    "setup:python-backends:check": "node scripts/run-powershell.cjs scripts/setup-python-backends.ps1 -CheckOnly",
    "setup:python-backends:offline-check": "node scripts/run-powershell.cjs scripts/setup-python-backends.ps1 -Offline -CheckOnly",
    "export:python-backend-reqs": "node scripts/run-powershell.cjs scripts/export-python-backend-requirements.ps1",
    "download:python-backend-wheelhouse-missing": "node scripts/download-missing-python-backend-wheels.cjs",
    "audit:release": "node scripts/run-powershell.cjs scripts/write-release-audit.ps1",
    "audit:release:strict": "node scripts/run-powershell.cjs scripts/write-release-audit.ps1 -Strict"
